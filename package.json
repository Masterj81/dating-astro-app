{
  "name": "astro-dating-monorepo",
  "version": "1.0.0",
  "private": true,
  "packageManager": "npm@10.8.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:mobile": "npm run start --workspace=@astro/mobile",
    "dev:web": "npm run dev --workspace=@astro/web",
    "build:mobile:android": "npm run build:android --workspace=@astro/mobile",
    "build:mobile:ios": "npm run build:ios --workspace=@astro/mobile",
    "build:web": "npm run build --workspace=@astro/web",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test --continue",
    "clean": "turbo clean && npx rimraf node_modules apps/*/node_modules packages/*/node_modules"
  },
  "devDependencies": {
    "rimraf": "^6.0.1",
    "turbo": "^2.0.0"
  },
  "overrides": {
    "@supabase/supabase-js": "^2.93.3",
    "typescript": "^5.9.2"
  }
}
