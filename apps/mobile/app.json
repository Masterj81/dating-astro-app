{
  "expo": {
    "name": "AstroDating",
    "slug": "astro-dating",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "astrodating",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.astrodating.app",
      "usesAppleSignIn": true,
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "NSPhotoLibraryUsageDescription": "AstroDating needs access to your photo library so you can select photos for your dating profile. For example, you can choose your best photos to show potential matches.",
        "NSCameraUsageDescription": "AstroDating needs camera access so you can take new photos for your dating profile and record a verification video.",
        "NSMicrophoneUsageDescription": "AstroDating needs microphone access to record your voice intro and verification video.",
        "NSSiriUsageDescription": "AstroDating uses Siri to check your horoscope and view matches.",
        "NSUserActivityTypes": [
          "CheckHoroscopeIntent",
          "ViewMatchesIntent",
          "CheckCompatibilityIntent"
        ]
      },
      "entitlements": {
        "com.apple.security.application-groups": [
          "group.com.astrodating.app"
        ],
        "com.apple.developer.siri": true
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#0f0f1a",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "edgeToEdgeEnabled": true,
      "package": "com.astrodatingapp.mobile",
      "versionCode": 24,
      "permissions": [
        "CAMERA",
        "RECORD_AUDIO"
      ],
      "blockedPermissions": [
        "android.permission.FOREGROUND_SERVICE_MEDIA_PLAYBACK"
      ]
    },
    "web": {
      "output": "single",
      "favicon": "./assets/images/favicon.png",
      "name": "AstroDating",
      "shortName": "AstroDating",
      "description": "Find your cosmic match through astrology",
      "themeColor": "#0f0f1a",
      "backgroundColor": "#0f0f1a",
      "display": "standalone",
      "orientation": "portrait",
      "startUrl": "/"
    },
    "plugins": [
      "@bacons/apple-targets",
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#0f0f1a"
        }
      ],
      "expo-localization",
      "expo-apple-authentication",
      [
        "@sentry/react-native/expo",
        {
          "url": "https://sentry.io/",
          "project": "astro-dating",
          "organization": "personnal-5l"
        }
      ],
      "expo-secure-store",
      [
        "expo-camera",
        {
          "cameraPermission": "AstroDating needs camera access to record your verification video.",
          "microphonePermission": "AstroDating needs microphone access for video recording.",
          "recordAudioAndroid": true
        }
      ],
      [
        "expo-audio",
        {
          "microphonePermission": "AstroDating needs microphone access to record your voice intro."
        }
      ],
      "expo-video"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "4b9ba994-e045-4aad-b3be-edee8bc22e2b"
      }
    }
  }
}
