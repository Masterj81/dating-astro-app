# Supabase
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# RevenueCat (In-App Purchases - iOS/Android)
EXPO_PUBLIC_REVENUECAT_API_KEY_IOS=
EXPO_PUBLIC_REVENUECAT_API_KEY_ANDROID=

# Stripe (Web Payments)
# Get these from https://dashboard.stripe.com
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
EXPO_PUBLIC_STRIPE_PRICE_CELESTIAL_MONTHLY=price_...
EXPO_PUBLIC_STRIPE_PRICE_CELESTIAL_YEARLY=price_...
EXPO_PUBLIC_STRIPE_PRICE_COSMIC_MONTHLY=price_...
EXPO_PUBLIC_STRIPE_PRICE_COSMIC_YEARLY=price_...
EXPO_PUBLIC_STRIPE_ANNUAL_COUPON_ID=

# Edge Function URL (for push notifications via pg_net)
# In production, set this to your deployed Supabase edge function URL
# e.g., https://your-project.supabase.co/functions/v1/send-notification
EDGE_FUNCTION_URL=

# Resend (Production Email)
# RESEND_API_KEY — set as a Supabase edge function secret: supabase secrets set RESEND_API_KEY=re_...
# RESEND_SMTP_KEY — same key, used for SMTP auth in Supabase Dashboard > Auth > SMTP
# EMAIL_FROM — sender address, e.g. AstroDating <noreply@astrodatingapp.com>
RESEND_API_KEY=
RESEND_SMTP_KEY=
EMAIL_FROM=AstroDating <noreply@astrodatingapp.com>

# Testing (never set to true in production)
EXPO_PUBLIC_FORCE_PREMIUM=false

# EAS Build
APP_ENV=development
